{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "My Anime 1996",
  "version": "0.1.1",
  "identifier": "com.myanime1996.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "title": "My Anime 1996",
        "url": "/splash.html",
        "width": 520,
        "height": 320,
        "center": true,
        "backgroundColor": "#0f0b09",
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "fullscreen": false
      },
      {
        "label": "main",
        "visible": false,
        "title": "My Anime 1996",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https:; img-src 'self' https: data: blob:; media-src 'self' https: data: blob:; frame-src https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'unsafe-inline' https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Entertainment",
    "shortDescription": "Retro anime metadata desktop app",
    "longDescription": "A Tauri desktop anime metadata browser with local sessions, playlists, watch history, and VHS-inspired UI."
  }
}
